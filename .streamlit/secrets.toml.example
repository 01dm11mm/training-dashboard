# ⚠️ このサンプルファイル(.example)には本物のトークンを書かないこと！ こちらはGitHubに上がります。

NOTION_TOKEN = "ntn_ここに自分のインテグレーションのシークレットを貼る"

# クラウド公開時のパスワード（設定すると起動時にパスワード画面が出る。ローカルだけなら空でも可）
APP_PASSWORD = "好きな合言葉"

